# Server Configuration
PORT=4000

# Database Configuration
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.abcde.mongodb.net/dbname

# Security
JWT_SECRET=your_jwt_secret_key_here

# AI Enrichment (Claude API)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Safepay Payment Gateway (Pakistani payment gateway — getsafepay.com)
# Sign up at: https://getsafepay.com/dashboard/register
# Use sandbox keys for testing, switch to live keys before launch
SAFEPAY_ENV=sandbox
SAFEPAY_PUBLIC_KEY=your_safepay_public_key_here
SAFEPAY_SECRET_KEY=your_safepay_secret_key_here
SAFEPAY_WEBHOOK_SECRET=your_safepay_webhook_secret_here
